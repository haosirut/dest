{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VaultKeeper",
  "version": "0.1.0",
  "identifier": "com.vaultkeeper.p2p",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "../dist",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss: asset: https://asset.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/**", "$DOWNLOAD/**", "$HOME/.vaultkeeper/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "deb", "dmg", "appimage", "nsis", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "2024 VaultKeeper P2P",
    "category": "Utility",
    "shortDescription": "P2P encrypted storage",
    "longDescription": "VaultKeeper decentralized P2P storage with client-side encryption",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": { "language": ["ru-RU"] }
    }
  },
  "plugins": {
    "store": { "path": "vaultkeeper_store.bin" },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoint": "https://github.com/haosirut/dest/releases/latest/download/latest.json",
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5MUYyQTE0QTFENzc5QUUKUldTdWVkZWhGQ29mK1JIanhrM1FLaG5YNmE0azNWeXcvc0MvcEF0OUY0UE5za1gxREV4M21yVFEK"
    }
  }
}
